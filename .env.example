## WSAPI Environment Variables
## All variables are optional - defaults are used when not set.
## Environment variables override config.yaml values.

## Server
# WSAPI_PORT=8080

## Database (WSAPI admin data)
# WSAPI_DB_DRIVER=sqlite
# WSAPI_DB_DSN=./data/wsapi.db

## Whatsmeow (device sessions and library settings)
# WSAPI_WHATSMEOW_DB_DRIVER=sqlite
# WSAPI_WHATSMEOW_DB_DSN=./data/whatsmeow.db
# WSAPI_WHATSMEOW_LOG_LEVEL=warn
# WSAPI_WHATSMEOW_PAIR_CLIENT_TYPE=chrome       # Pair client type: chrome, edge, firefox, opera, safari (default: chrome)
# WSAPI_WHATSMEOW_PAIR_CLIENT_DISPLAY_NAME=Chrome (Windows)  # Display name shown during QR pairing

## Authentication
# WSAPI_ADMIN_API_KEY=

## Logging
# WSAPI_LOG_LEVEL=info
# WSAPI_LOG_FORMAT=text
# WSAPI_LOG_REDACT=true               # Redact sensitive fields from event logs (default: true)

## HTTP proxy for outbound requests (webhook delivery, media URL downloads)
# WSAPI_HTTP_PROXY=http://proxy.example.com:8080

## Instance defaults
# WSAPI_DEFAULT_API_KEY=
# WSAPI_DEFAULT_WEBHOOK_URL=
# WSAPI_DEFAULT_SIGNING_SECRET=
# WSAPI_DEFAULT_EVENT_FILTERS=message,message_read,group
# WSAPI_DEFAULT_HISTORY_SYNC=false

## Event publishing
# WSAPI_PUBLISH_VIA=none              # "webhook", "redis", or "none"

## Redis (optional)
# WSAPI_REDIS_MODE=standalone           # "standalone" (default) or "sentinel"
# WSAPI_REDIS_URL=localhost:6379        # host:port for standalone; comma-separated sentinel addrs for sentinel
# WSAPI_REDIS_PASSWORD=
# WSAPI_REDIS_DB=0
# WSAPI_REDIS_STREAM_NAME=             # Fixed stream name; default: "stream:<instanceId>"
# WSAPI_REDIS_TLS=false                # Enable TLS
# WSAPI_REDIS_TLS_INSECURE=false       # Skip TLS certificate verification
# WSAPI_REDIS_MASTER_NAME=mymaster     # Sentinel master name
# WSAPI_REDIS_SENTINEL_PASSWORD=       # Sentinel auth password
